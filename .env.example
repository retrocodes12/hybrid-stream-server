STREMIO_ADDON_ID=community.nebulastreams
STREMIO_ADDON_NAME=NebulaStreams
TMDB_API_KEY=439c478a771f35c05022f9feabcca01c

# Render-friendly defaults
CACHE_DIR=/tmp/nebulastreams-cache
MAX_CACHE_SIZE_GB=1
PROVIDER_TIMEOUT_SECONDS=10
PROVIDER_MAX_CONCURRENCY=3
HTTP_MAX_SOCKETS=4
HTTP_MAX_FREE_SOCKETS=2
HTTP_KEEP_ALIVE_MILLISECONDS=1000

# The addon now returns direct HTTP URLs and native Stremio torrent entries,
# so playback does not depend on the hosting box for media delivery.
